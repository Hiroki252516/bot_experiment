POSTGRES_DB=tutorbot
POSTGRES_USER=tutorbot
POSTGRES_PASSWORD=tutorbot
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://tutorbot:tutorbot@db:5432/tutorbot

APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/data/uploads
EXPORT_DIR=/app/data/exports
SEED_DIR=/app/seeds/sample_corpus
HF_HOME=/app/model_cache/huggingface
TRANSFORMERS_CACHE=/app/model_cache/huggingface/transformers
SENTENCE_TRANSFORMERS_HOME=/app/model_cache/sentence-transformers

# LLM_PROVIDER is kept for backward compatibility. Prefer GENERATION_PROVIDER.
GENERATION_PROVIDER=gemini
EMBEDDING_PROVIDER=local-sentence-transformers
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_GENERATE=gemini-2.0-flash
GEMINI_MODEL_EMBED=gemini-embedding-001
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LOCAL_EMBED_MODEL=pkshatech/GLuCoSE-base-ja
LOCAL_EMBED_DEVICE=auto
LOCAL_EMBED_BATCH_SIZE=16
LOCAL_EMBED_NORMALIZE=true
LOCAL_EMBED_HTTP_URL=http://host.docker.internal:8088

DEFAULT_CANDIDATE_COUNT=3
DEFAULT_RETRIEVAL_TOP_K=5
DEFAULT_CHUNK_SIZE=1200
DEFAULT_CHUNK_OVERLAP=200
EMBEDDING_DIMENSIONS=768
SKILL_UPDATER_POLL_INTERVAL_SECONDS=5
JOB_BATCH_SIZE=10

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
